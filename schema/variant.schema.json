{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://registry.mzget.unimz.org/schema/variant.schema.json",
  "title": "MzGet checksum variant record",
  "type": "object",
  "required": ["schema_version", "source", "dataset_accession", "file_accession", "sha256", "verification_state"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "source": { "type": "string" },
    "dataset_accession": { "type": "string" },
    "file_accession": { "type": "string" },
    "sha256": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" },
    "blake3": { "type": ["string", "null"], "pattern": "^[0-9a-fA-F]{64}$" },
    "block_size": { "type": ["integer", "null"], "minimum": 1 },
    "block_hash_algorithm": { "type": ["string", "null"], "enum": ["blake3", null] },
    "blocks": {
      "type": ["array", "null"],
      "items": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" }
    },
    "merkle_root": { "type": ["string", "null"], "pattern": "^[0-9a-fA-F]{64}$" },
    "verification_state": {
      "type": "string",
      "enum": ["official", "community_verified", "candidate", "conflict_candidate", "superseded", "historical"]
    },
    "observations": { "type": "array" }
  },
  "additionalProperties": true
}
