{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://registry.mzget.unimz.org/schema/observation.schema.json",
  "title": "MzGet verification observation",
  "type": "object",
  "required": ["schema_version", "source", "dataset_accession", "file_accession", "observed_at_unix_seconds", "sha256"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "source": { "type": "string" },
    "dataset_accession": { "type": "string" },
    "file_accession": { "type": "string" },
    "observed_at_unix_seconds": { "type": "integer" },
    "sha256": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" },
    "blake3": { "type": ["string", "null"], "pattern": "^[0-9a-fA-F]{64}$" },
    "file_name": { "type": ["string", "null"] },
    "file_size_bytes": { "type": ["integer", "null"], "minimum": 0 },
    "block_size": { "type": ["integer", "null"], "minimum": 1 },
    "block_hash_algorithm": { "type": ["string", "null"], "enum": ["blake3", null] },
    "blocks": {
      "type": ["array", "null"],
      "items": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" }
    },
    "merkle_root": { "type": ["string", "null"], "pattern": "^[0-9a-fA-F]{64}$" },
    "verification_state": { "type": ["string", "null"] },
    "path": { "type": ["string", "null"] },
    "submitter": { "type": ["string", "null"] },
    "tool": { "type": ["object", "null"] },
    "format_qc": { "type": ["object", "null"] }
  },
  "additionalProperties": true
}
