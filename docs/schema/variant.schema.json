{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://registry.mzget.unimz.org/schema/variant.schema.json",
  "title": "MzGet checksum variant record",
  "type": "object",
  "required": ["schema_version", "source", "dataset_accession", "file_accession", "sha256", "verification_state"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "source": { "type": "string" },
    "dataset_accession": { "type": "string" },
    "file_accession": { "type": "string" },
    "sha256": { "type": "string" },
    "blake3": { "type": ["string", "null"] },
    "block_size": { "type": ["integer", "null"] },
    "merkle_root": { "type": ["string", "null"] },
    "verification_state": { "type": "string" },
    "observations": { "type": "array" }
  },
  "additionalProperties": true
}
