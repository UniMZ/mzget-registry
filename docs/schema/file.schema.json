{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://registry.mzget.unimz.org/schema/file.schema.json",
  "title": "MzGet file record",
  "type": "object",
  "required": ["schema_version", "source", "dataset_accession", "file_accession", "file_name", "repository_size_bytes", "public_locations"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "source": { "type": "string" },
    "dataset_accession": { "type": "string" },
    "file_accession": { "type": "string" },
    "file_name": { "type": "string" },
    "category": { "type": ["string", "null"] },
    "category_name": { "type": ["string", "null"] },
    "repository_size_bytes": { "type": ["integer", "null"], "minimum": 0 },
    "repository_size_kind": { "type": "string" },
    "checksum": { "type": ["string", "null"] },
    "checksum_source": { "type": ["string", "null"] },
    "public_locations": { "type": "array" },
    "preferred_download_url": { "type": ["string", "null"] },
    "variants": { "type": "array" }
  },
  "additionalProperties": true
}
