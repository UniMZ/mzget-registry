{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://registry.mzget.unimz.org/schema/dataset.schema.json",
  "title": "MzGet dataset record",
  "type": "object",
  "required": ["schema_version", "source", "accession", "file_count", "total_size_bytes", "files"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "source": { "type": "string" },
    "accession": { "type": "string" },
    "source_retrieved_at_unix_seconds": { "type": ["integer", "null"] },
    "file_count": { "type": "integer", "minimum": 0 },
    "total_size_bytes": { "type": "integer", "minimum": 0 },
    "files": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
